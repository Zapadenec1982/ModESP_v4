{
  "manifest_version": 1,
  "module": "thermostat",
  "description": "On/off thermostat with asymmetric differential, fan control, safety run (spec_v3)",

  "inputs": {
    "equipment.air_temp": {
      "source_module": "equipment",
      "type": "float",
      "description": "Температура камери від Equipment Manager",
      "optional": false
    },
    "equipment.evap_temp": {
      "source_module": "equipment",
      "type": "float",
      "description": "Температура випарника від Equipment Manager",
      "optional": true
    },
    "equipment.sensor1_ok": {
      "source_module": "equipment",
      "type": "bool",
      "description": "Здоров'я датчика камери",
      "optional": false
    },
    "equipment.sensor2_ok": {
      "source_module": "equipment",
      "type": "bool",
      "description": "Здоров'я датчика випарника",
      "optional": true
    },
    "equipment.compressor": {
      "source_module": "equipment",
      "type": "bool",
      "description": "Фактичний стан компресора (для UI)",
      "optional": false
    },
    "defrost.active": {
      "source_module": "defrost",
      "type": "bool",
      "description": "Чи активна розморозка",
      "optional": true
    },
    "defrost.phase": {
      "source_module": "defrost",
      "type": "string",
      "description": "Фаза розморозки (fad тощо)",
      "optional": true
    },
    "protection.lockout": {
      "source_module": "protection",
      "type": "bool",
      "description": "Аварійна зупинка від Protection",
      "optional": true
    }
  },

  "state": {
    "thermostat.temperature": {
      "type": "float",
      "unit": "\u00b0C",
      "access": "read",
      "description": "Поточна температура камери"
    },
    "thermostat.setpoint": {
      "type": "float",
      "unit": "\u00b0C",
      "access": "readwrite",
      "min": -50.0,
      "max": 50.0,
      "step": 0.5,
      "default": 4.0,
      "persist": true,
      "description": "Уставка температури"
    },
    "thermostat.differential": {
      "type": "float",
      "unit": "\u00b0C",
      "access": "readwrite",
      "min": 0.1,
      "max": 10.0,
      "step": 0.1,
      "default": 2.0,
      "persist": true,
      "description": "Диференціал (вгору від уставки)"
    },
    "thermostat.min_off_time": {
      "type": "int",
      "unit": "с",
      "access": "readwrite",
      "min": 0,
      "max": 600,
      "step": 1,
      "default": 180,
      "persist": true,
      "description": "Мін. час паузи компресора (cFt)"
    },
    "thermostat.min_on_time": {
      "type": "int",
      "unit": "с",
      "access": "readwrite",
      "min": 0,
      "max": 600,
      "step": 1,
      "default": 60,
      "persist": true,
      "description": "Мін. час роботи компресора (cOt)"
    },
    "thermostat.startup_delay": {
      "type": "int",
      "unit": "с",
      "access": "readwrite",
      "min": 0,
      "max": 300,
      "step": 1,
      "default": 60,
      "persist": true,
      "description": "Затримка після подачі живлення"
    },
    "thermostat.evap_fan_mode": {
      "type": "int",
      "unit": "",
      "access": "readwrite",
      "min": 0,
      "max": 2,
      "step": 1,
      "default": 1,
      "persist": true,
      "description": "Режим вент. випарника (0=пост, 1=з компр, 2=за T_evap)"
    },
    "thermostat.fan_stop_temp": {
      "type": "float",
      "unit": "\u00b0C",
      "access": "readwrite",
      "min": -40.0,
      "max": 10.0,
      "step": 0.5,
      "default": -25.0,
      "persist": true,
      "description": "T зупинки вент. випарника (FST, для FAn=2)"
    },
    "thermostat.fan_stop_hyst": {
      "type": "float",
      "unit": "\u00b0C",
      "access": "readwrite",
      "min": 0.5,
      "max": 5.0,
      "step": 0.5,
      "default": 2.0,
      "persist": true,
      "description": "Гістерезис FST (для FAn=2)"
    },
    "thermostat.cond_fan_delay": {
      "type": "int",
      "unit": "с",
      "access": "readwrite",
      "min": 0,
      "max": 120,
      "step": 1,
      "default": 30,
      "persist": true,
      "description": "Затримка вимк. вент. конденсатора (COd)"
    },
    "thermostat.safety_run_on": {
      "type": "int",
      "unit": "хв",
      "access": "readwrite",
      "min": 1,
      "max": 60,
      "step": 1,
      "default": 20,
      "persist": true,
      "description": "Час роботи в Safety Run"
    },
    "thermostat.safety_run_off": {
      "type": "int",
      "unit": "хв",
      "access": "readwrite",
      "min": 1,
      "max": 60,
      "step": 1,
      "default": 10,
      "persist": true,
      "description": "Час паузи в Safety Run"
    },
    "thermostat.req.compressor": {
      "type": "bool",
      "access": "read",
      "description": "Запит на компресор (до Equipment Manager)"
    },
    "thermostat.req.evap_fan": {
      "type": "bool",
      "access": "read",
      "description": "Запит на вент. випарника (до Equipment Manager)"
    },
    "thermostat.req.cond_fan": {
      "type": "bool",
      "access": "read",
      "description": "Запит на вент. конденсатора (до Equipment Manager)"
    },
    "thermostat.state": {
      "type": "string",
      "access": "read",
      "enum": ["startup", "idle", "cooling", "safety_run"],
      "description": "Стан модуля"
    },
    "thermostat.comp_on_time": {
      "type": "int",
      "unit": "с",
      "access": "read",
      "description": "Час роботи компресора"
    },
    "thermostat.comp_off_time": {
      "type": "int",
      "unit": "с",
      "access": "read",
      "description": "Час простою компресора"
    }
  },

  "ui": {
    "page": "Холодильна камера",
    "page_id": "thermostat",
    "icon": "snowflake",
    "order": 1,
    "cards": [
      {
        "title": "Температура",
        "widgets": [
          {
            "key": "thermostat.temperature",
            "widget": "value"
          },
          {
            "key": "thermostat.setpoint",
            "widget": "slider"
          }
        ]
      },
      {
        "title": "Стан системи",
        "widgets": [
          {
            "key": "equipment.compressor",
            "widget": "indicator",
            "on_label": "Працює",
            "off_label": "Вимкнено",
            "on_color": "#22c55e",
            "off_color": "#64748b"
          },
          {
            "key": "thermostat.state",
            "widget": "status_text"
          },
          {
            "key": "thermostat.comp_on_time",
            "widget": "value",
            "label": "Час роботи"
          },
          {
            "key": "thermostat.comp_off_time",
            "widget": "value",
            "label": "Час простою"
          }
        ]
      },
      {
        "title": "Уставки",
        "group": "settings",
        "collapsible": true,
        "widgets": [
          {
            "key": "thermostat.setpoint",
            "widget": "number_input"
          },
          {
            "key": "thermostat.differential",
            "widget": "number_input"
          }
        ]
      },
      {
        "title": "Захист компресора",
        "group": "settings",
        "collapsible": true,
        "widgets": [
          {
            "key": "thermostat.min_off_time",
            "widget": "number_input"
          },
          {
            "key": "thermostat.min_on_time",
            "widget": "number_input"
          },
          {
            "key": "thermostat.startup_delay",
            "widget": "number_input"
          }
        ]
      },
      {
        "title": "Вентиляція",
        "group": "settings",
        "collapsible": true,
        "widgets": [
          {
            "key": "thermostat.evap_fan_mode",
            "widget": "number_input"
          },
          {
            "key": "thermostat.fan_stop_temp",
            "widget": "number_input"
          },
          {
            "key": "thermostat.fan_stop_hyst",
            "widget": "number_input"
          },
          {
            "key": "thermostat.cond_fan_delay",
            "widget": "number_input"
          }
        ]
      },
      {
        "title": "Safety Run",
        "group": "settings",
        "collapsible": true,
        "widgets": [
          {
            "key": "thermostat.safety_run_on",
            "widget": "number_input"
          },
          {
            "key": "thermostat.safety_run_off",
            "widget": "number_input"
          }
        ]
      }
    ]
  },

  "mqtt": {
    "publish": [
      "thermostat.temperature",
      "thermostat.req.compressor",
      "thermostat.req.evap_fan",
      "thermostat.req.cond_fan",
      "thermostat.state",
      "thermostat.comp_on_time",
      "thermostat.comp_off_time"
    ],
    "subscribe": [
      "thermostat.setpoint",
      "thermostat.differential",
      "thermostat.min_off_time",
      "thermostat.min_on_time",
      "thermostat.startup_delay",
      "thermostat.evap_fan_mode",
      "thermostat.fan_stop_temp",
      "thermostat.fan_stop_hyst",
      "thermostat.cond_fan_delay",
      "thermostat.safety_run_on",
      "thermostat.safety_run_off"
    ]
  },

  "display": {
    "main_value": {
      "key": "thermostat.temperature",
      "format": "%.1f\u00b0C"
    },
    "menu_items": [
      {"label": "Уставка",      "key": "thermostat.setpoint"},
      {"label": "Диференціал",  "key": "thermostat.differential"},
      {"label": "Пауза cFt",   "key": "thermostat.min_off_time"},
      {"label": "Робота cOt",   "key": "thermostat.min_on_time"}
    ]
  }
}
